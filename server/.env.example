# Neon (or any Postgres) connection string
DATABASE_URL=postgres://user:password@ep-your-instance.neon.tech/claude_split?sslmode=require

# Port the API listens on
PORT=8080

# Comma-separated list of allowed CORS origins.
# Add your extension origins after installing the extension (see SETUP.md).
CORS_ORIGINS=chrome-extension://<your-extension-id>,moz-extension://<your-extension-id>

# API token lifetime (sliding) in days
TOKEN_TTL_DAYS=30

# Default usage_events retention in days (per-user override via settings)
RETENTION_DAYS=90
