# Neon (or any Postgres) connection string
DATABASE_URL=postgres://user:password@ep-your-instance.neon.tech/claude_split?sslmode=require

# Port the API listens on
PORT=8080

# OPTIONAL: extra allowed CORS origins (comma-separated), e.g. a web dashboard.
# Browser-extension origins (chrome-extension://, moz-extension://) are always
# allowed automatically — no configuration needed per install.
CORS_ORIGINS=

# API token lifetime (sliding) in days
TOKEN_TTL_DAYS=30

# Default usage_events retention in days (per-user override via settings)
RETENTION_DAYS=90
