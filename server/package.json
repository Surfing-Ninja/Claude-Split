{
  "name": "@claude-split/server",
  "version": "0.1.0",
  "private": true,
  "description": "Claude Split backend — auth, devices, usage attribution, summary",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "migrate": "tsx src/db/migrate.ts",
    "generate": "drizzle-kit generate",
    "test": "vitest run"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "drizzle-orm": "^0.44.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "pg": "^8.13.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.0",
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "drizzle-kit": "^0.31.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}
