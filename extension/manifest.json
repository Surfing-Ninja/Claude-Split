{
  "manifest_version": 3,
  "name": "Claude Split",
  "version": "0.1.0",
  "description": "Personal multi-device usage tracker for your own Claude Pro/Max account. Not an account-sharing tool.",
  "permissions": ["storage", "alarms", "cookies"],
  "host_permissions": ["https://claude.ai/*"],
  "background": {
    "service_worker": "src/background/worker.js",
    "scripts": ["src/background/worker.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "js": ["src/content/main.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected/bridge.js", "src/lib/usage-parser.js"],
      "matches": ["https://claude.ai/*"]
    }
  ],
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Claude Split"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "claude-split@claude-split.dev",
      "strict_min_version": "121.0"
    }
  }
}
